#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
# codex-diag — Codex + DeepSeek 网络一键诊断脚本
# 用法: codex-diag [--json]
# ═══════════════════════════════════════════════════════════════

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

PASS="${GREEN}✓${NC}"
FAIL="${RED}✗${NC}"
WARN="${YELLOW}⚠${NC}"
INFO="${CYAN}→${NC}"

JSON_OUTPUT=false
[[ "$1" == "--json" ]] && JSON_OUTPUT=true

TMPJSON="/tmp/codex-diag-$$.json"

add_result() {
  local key="$1" status="$2" msg="$3"
  echo "{\"key\":\"$key\",\"status\":\"$status\",\"message\":\"$msg\"}," >> "$TMPJSON"
  if [[ "$JSON_OUTPUT" == false ]]; then
    case "$status" in
      pass) echo -e "  $PASS $msg" ;;
      fail) echo -e "  $FAIL $msg" ;;
      warn) echo -e "  $WARN $msg" ;;
      info) echo -e "  $INFO $msg" ;;
    esac
  fi
}

FAIL_COUNT=0
WARN_COUNT=0
PASS_COUNT=0

inc() {
  case "$1" in
    fail) ((FAIL_COUNT++)) ;;
    warn) ((WARN_COUNT++)) ;;
    pass) ((PASS_COUNT++)) ;;
  esac
}

echo '[' > "$TMPJSON"  # Start JSON array

header() {
  if [[ "$JSON_OUTPUT" == false ]]; then
    echo ""
    echo -e "${CYAN}── $1 ──${NC}"
  fi
}

if [[ "$JSON_OUTPUT" == false ]]; then
  echo ""
  echo -e "${CYAN}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${CYAN}║   Codex + DeepSeek 网络诊断工具             ║${NC}"
  echo -e "${CYAN}╚══════════════════════════════════════════════╝${NC}"
  echo ""
  echo -e "  时间: $(date '+%Y-%m-%d %H:%M:%S')"
  echo -e "  主机: $(hostname -s 2>/dev/null || echo unknown)"
  echo ""
fi

VPN_ACTIVE=false
VPN_NAME=""

# ─── 1. VPN 检测 ─────────────────────────────────────────

header "VPN 状态"

nc_list=$(scutil --nc list 2>/dev/null || true)
if echo "$nc_list" | grep -q "(Connected)"; then
  VPN_ACTIVE=true
  VPN_NAME=$(echo "$nc_list" | grep "(Connected)" | grep -oE '"[^"]+"' | head -1 | tr -d '"')
  add_result vpn warn "VPN 已连接: $VPN_NAME" ; inc warn
elif echo "$nc_list" | grep -qi "vpn"; then
  VPN_NAME=$(echo "$nc_list" | grep -i "vpn" | head -1 | grep -oE '"[^"]+"' | tr -d '"')
  add_result vpn pass "VPN 未连接" ; inc pass
else
  add_result vpn pass "未检测到 VPN 服务" ; inc pass
fi

utun_count=$(ifconfig 2>/dev/null | grep -c "^utun" || echo 0)
if [[ $utun_count -ge 10 ]] && [[ "$VPN_ACTIVE" == false ]]; then
  add_result utun warn "检测到 $utun_count 个 tunnel 接口（VPN 可能仍在运行）" ; inc warn
fi

# ─── 2. 代理服务状态 ──────────────────────────────────────

header "代理服务"

if lsof -i :10204 -P -n 2>/dev/null | grep -q LISTEN; then
  pid=$(lsof -i :10204 -P -n 2>/dev/null | grep LISTEN | awk '{print $2}' | head -1)
  add_result proxy_port pass "端口 10204 已监听 (PID: $pid)" ; inc pass

  health=$(curl -s --max-time 3 http://localhost:10204/v1/health 2>/dev/null || true)
  if [[ -n "$health" ]]; then
    uptime_s=$(echo "$health" | python3 -c "import sys,json; print(json.load(sys.stdin).get('uptime',0))" 2>/dev/null || echo 0)
    errors=$(echo "$health" | python3 -c "import sys,json; print(json.load(sys.stdin).get('errors',0))" 2>/dev/null || echo 0)
    reqs=$(echo "$health" | python3 -c "import sys,json; print(json.load(sys.stdin).get('requests',0))" 2>/dev/null || echo 0)
    h=$((uptime_s / 3600))
    m=$(((uptime_s % 3600) / 60))
    add_result proxy_health pass "代理健康检查正常 (${h}h${m}m, ${reqs}请求, ${errors}错误)" ; inc pass
  else
    add_result proxy_health fail "代理端口在监听但无响应" ; inc fail
  fi
else
  add_result proxy_port fail "端口 10204 未监听！代理未运行" ; inc fail
  add_result proxy_health fail "代理不可用" ; inc fail
fi

# ─── 3. DeepSeek API 可达性 ──────────────────────────────

header "DeepSeek API"

# DNS
dns_ips=$(python3 -c "
import socket
try:
    ips = socket.getaddrinfo('api.deepseek.com', 443)
    print(','.join(sorted(set(ip[4][0] for ip in ips))))
except Exception as e:
    print('FAIL:' + str(e))
" 2>/dev/null || echo "FAIL:unknown")

if [[ "$dns_ips" == FAIL:* ]]; then
  add_result dns fail "DNS 解析失败: ${dns_ips#FAIL:}" ; inc fail
  if $VPN_ACTIVE; then
    add_result dns_hint warn "VPN 可能干扰了 DNS 解析" ; inc warn
  fi
else
  add_result dns pass "DNS 解析正常 → $(echo $dns_ips | tr ',' ' ')" ; inc pass
fi

# TCP 连通性
http_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 \
  https://api.deepseek.com/v1/models \
  -H "Authorization: Bearer test" 2>/dev/null || echo "000")

if [[ "$http_code" == "200" || "$http_code" == "401" ]]; then
  add_result api_reachable pass "DeepSeek API 可达 (HTTP $http_code)" ; inc pass
elif [[ "$http_code" == "000" ]]; then
  add_result api_reachable fail "DeepSeek API 不可达（连接超时或网络不通）" ; inc fail
  if $VPN_ACTIVE; then
    add_result api_hint warn "VPN 正在运行。DeepSeek 是国内服务，VPN 可能导致无法访问。建议关闭 VPN 或配置分流规则。" ; inc warn
  fi
else
  add_result api_reachable warn "DeepSeek API 返回 HTTP $http_code" ; inc warn
fi

# Latency
latency=$(curl -s -o /dev/null -w "%{time_total}" --max-time 5 \
  https://api.deepseek.com/v1/models \
  -H "Authorization: Bearer test" 2>/dev/null || echo "0")
if [[ -n "$latency" && "$latency" != "0" && "$latency" != "0.000"* ]]; then
  add_result latency info "延迟: ${latency}s" ; inc pass
fi

# ─── 4. API 余额 ──────────────────────────────────────────

header "API 余额"

CONFIG_FILE="$HOME/.codex-proxy/config.yaml"
if [[ -f "$CONFIG_FILE" ]]; then
  balance_info=$(python3 << 'PYEOF' 2>/dev/null
import yaml, subprocess, json, sys
with open('/Users/sgl/.codex-proxy/config.yaml') as f:
    cfg = yaml.safe_load(f)
api_key = None
for ch in (cfg.get('channels') or {}).values():
    k = ch.get('api_key','')
    if k and not k.startswith('sk-你的'):
        api_key = k
        break
if not api_key:
    print('NO_KEY')
    sys.exit(0)

# 使用 curl 代替 urllib 避免 Python SSL 证书问题
try:
    result = subprocess.run([
        'curl', '-s', '--max-time', '10',
        '-H', f'Authorization: Bearer {api_key}',
        'https://api.deepseek.com/user/balance'
    ], capture_output=True, text=True, timeout=12)
    data = json.loads(result.stdout)
    if data.get('is_available'):
        for b in data.get('balance_infos', []):
            print(f"AVAIL|{b.get('total_balance','?')}|{b.get('currency','CNY')}")
    else:
        print('UNAVAIL')
except Exception as e:
    print(f'ERROR|{e}')
PYEOF
)

  case "$balance_info" in
    AVAIL\|*)
      bal=$(echo "$balance_info" | cut -d'|' -f2)
      cur=$(echo "$balance_info" | cut -d'|' -f3)
      add_result balance pass "API Key 有效 (余额: $cur $bal)" ; inc pass
      ;;
    NO_KEY)
      add_result balance warn "API Key 未配置" ; inc warn
      ;;
    ERROR\|*)
      err_msg=$(echo "$balance_info" | cut -d'|' -f2)
      add_result balance warn "无法获取余额: $err_msg" ; inc warn
      ;;
    *)
      add_result balance warn "余额查询返回异常" ; inc warn
      ;;
  esac
else
  add_result balance warn "配置文件不存在: $CONFIG_FILE" ; inc warn
fi

# ─── 5. Codex 配置 ────────────────────────────────────────

header "Codex 配置"

CODEX_CONFIG="$HOME/.codex/config.toml"
if [[ -f "$CODEX_CONFIG" ]]; then
  model=$(grep "^model = " "$CODEX_CONFIG" 2>/dev/null | head -1 | sed 's/.*= //' | tr -d '"'"'" | xargs)
  base_url=$(grep "^base_url = " "$CODEX_CONFIG" 2>/dev/null | head -1 | sed 's/.*= //' | tr -d '"'"'" | xargs)

  if [[ "$model" == "deepseek-chat" ]]; then
    add_result codex_model pass "默认模型: $model" ; inc pass
  elif [[ -n "$model" ]]; then
    add_result codex_model warn "默认模型: $model（非 DeepSeek）" ; inc warn
  else
    add_result codex_model warn "未设置默认模型" ; inc warn
  fi

  if [[ "$base_url" == "http://localhost:10204/v1" ]]; then
    add_result codex_proxy pass "代理地址正确: $base_url" ; inc pass
  elif [[ -n "$base_url" ]]; then
    add_result codex_proxy warn "代理地址: $base_url" ; inc warn
  else
    add_result codex_proxy warn "未配置代理地址" ; inc warn
  fi

  cache="$HOME/.codex/models_cache.json"
  if [[ -f "$cache" ]]; then
    ds_count=$(python3 -c "
import json
with open('$cache') as f:
    data = json.load(f)
print(sum(1 for m in data.get('models',[]) if 'deepseek' in m.get('slug','')))
" 2>/dev/null || echo 0)
    if [[ "$ds_count" -ge 4 ]]; then
      add_result codex_cache pass "模型缓存已注册 $ds_count 个 DeepSeek 模型" ; inc pass
    else
      add_result codex_cache fail "模型缓存中仅 $ds_count 个 DeepSeek 模型（需要 4 个）" ; inc fail
    fi
  fi
else
  add_result codex_config warn "Codex 配置文件不存在" ; inc warn
fi

# ─── 6. 总结 ──────────────────────────────────────────────

# Close JSON array
# Remove trailing comma from last entry
if [[ "$JSON_OUTPUT" == true ]]; then
  # Build complete JSON
  sed '$ s/,$//' "$TMPJSON" > "${TMPJSON}.fixed"
  echo ']' >> "${TMPJSON}.fixed"
  python3 -c "
import json,sys
items = json.load(open('${TMPJSON}.fixed'))
result = {
    'summary': {'pass': $PASS_COUNT, 'warn': $WARN_COUNT, 'fail': $FAIL_COUNT},
    'vpn_active': ${VPN_ACTIVE},
    'vpn_name': '${VPN_NAME}',
    'items': {item['key']: {'status': item['status'], 'message': item['message']} for item in items}
}
print(json.dumps(result, indent=2, ensure_ascii=False))
"
  rm -f "$TMPJSON" "${TMPJSON}.fixed"
else
  rm -f "$TMPJSON"
  echo ""
  echo -e "${CYAN}── 诊断总结 ──${NC}"
  if [[ $FAIL_COUNT -eq 0 && $WARN_COUNT -eq 0 ]]; then
    echo -e "  ${GREEN}✓ 一切正常${NC} — 代理运行，DeepSeek 可达，配置正确"
  elif [[ $FAIL_COUNT -eq 0 ]]; then
    echo -e "  ${YELLOW}⚠ 有 $WARN_COUNT 个警告${NC} — 建议检查上述黄色标记项"
  else
    echo -e "  ${RED}✗ 有 $FAIL_COUNT 个问题和 $WARN_COUNT 个警告${NC}"
    if $VPN_ACTIVE; then
      echo ""
      echo -e "  ${YELLOW}┌─────────────────────────────────────────────────┐${NC}"
      echo -e "  ${YELLOW}│ 检测到 VPN 正在运行                              │${NC}"
      echo -e "  ${YELLOW}│                                                 │${NC}"
      echo -e "  ${YELLOW}│ DeepSeek API 为国内服务，VPN 可能导致无法连接。  │${NC}"
      echo -e "  ${YELLOW}│ 请尝试关闭 VPN 后重试，或执行:                   │${NC}"
      echo -e "  ${YELLOW}│   curl http://localhost:10204/v1/health?deep=vpn│${NC}"
      echo -e "  ${YELLOW}└─────────────────────────────────────────────────┘${NC}"
    fi
  fi
  echo ""
fi
